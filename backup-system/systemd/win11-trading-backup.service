[Unit]
Description=Win11-Trading powered-off VM backup
Documentation=file://__BACKUP_ROOT__/README.md
After=virtqemud.service libvirtd.service

[Service]
Type=oneshot
ExecStart=/run/current-system/sw/bin/bash __BACKUP_ROOT__/bin/backup-vm.sh
Environment=PATH=/run/current-system/sw/bin
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=7
